pipeline {
    agent any

    environment {
        PATH = "/opt/homebrew/bin:/usr/local/bin:/Applications/Docker.app/Contents/Resources/bin:/usr/bin:/bin:/usr/sbin:/sbin:${env.PATH}"
        KUBECONFIG = "/Users/prathameshswami/.kube/config"
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Verify Tools') {
            steps {
                sh 'echo $PATH'
                sh 'which docker || true'
                sh 'python3 --version || true'
                sh 'docker --version || true'
                sh 'which kubectl || true'
                sh 'kubectl version --client || true'
                sh 'kubectl config current-context || true'
            }
        }

        stage('Install Python Dependencies') {
            steps {
                sh '''
                    if command -v python3 >/dev/null 2>&1; then
                        python3 -m venv .venv
                        . .venv/bin/activate
                        python -m pip install --upgrade pip
                        python -m pip install -r requirements.txt
                    else
                        echo "python3 not found in Jenkins runtime. Skipping dependency installation for demo pipeline."
                    fi
                '''
            }
        }

        stage('Run Basic Application Checks') {
            steps {
                sh '''
                    if [ -x .venv/bin/python ]; then
                        . .venv/bin/activate
                        python -m py_compile app.py
                    else
                        echo "Virtual environment not available. Skipping Python compile check for demo pipeline."
                    fi
                '''
                sh '''
                    if [ -x .venv/bin/python ]; then
                        . .venv/bin/activate
                        python -c "from app import app; print(app.url_map)"
                    else
                        echo "Virtual environment not available. Skipping Flask route map check for demo pipeline."
                    fi
                '''
            }
        }

        stage('Build Docker Image') {
            steps {
                sh '''
                    if command -v docker >/dev/null 2>&1; then
                        docker build -t skynetx-app:1.0 .
                    else
                        echo "docker not found in Jenkins runtime. Skipping image build for demo pipeline."
                    fi
                '''
            }
        }

        stage('Apply Kubernetes Manifests') {
            steps {
                sh '''
                    if command -v kubectl >/dev/null 2>&1; then
                        kubectl apply -f kubernetes/
                    else
                        echo "kubectl not found in Jenkins runtime. Skipping Kubernetes apply for demo pipeline."
                    fi
                '''
            }
        }

        stage('Verify Kubernetes Rollout') {
            steps {
                sh '''
                    if command -v kubectl >/dev/null 2>&1; then
                        kubectl rollout status deployment/skynetx-app -n skynetx
                    else
                        echo "kubectl not found in Jenkins runtime. Skipping rollout verification for demo pipeline."
                    fi
                '''
            }
        }

        stage('Show Pods and Service') {
            steps {
                sh '''
                    if command -v kubectl >/dev/null 2>&1; then
                        kubectl get pods -n skynetx
                    else
                        echo "kubectl not found in Jenkins runtime. Skipping pod listing for demo pipeline."
                    fi
                '''
                sh '''
                    if command -v kubectl >/dev/null 2>&1; then
                        kubectl get svc -n skynetx
                    else
                        echo "kubectl not found in Jenkins runtime. Skipping service listing for demo pipeline."
                    fi
                '''
            }
        }
    }
}
